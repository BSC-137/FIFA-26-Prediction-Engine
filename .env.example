# API-Football (https://www.api-football.com/) API key.
# Leave empty to use mock data for offline development.
API_FOOTBALL_KEY=

# Cache time-to-live in seconds for provider responses.
CACHE_TTL_SECONDS=3600

# API-Football competition / league IDs (World Cup 2026 when available).
WORLD_CUP_COMPETITION_ID=1
WORLD_CUP_SEASON=2026

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

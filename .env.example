# API-Football (https://www.api-football.com/) API key — only needed if DATA_PROVIDER=api-football.
# Leave empty when using the default openfootball WC 2026 data source.
API_FOOTBALL_KEY=

# Fixture data source: openfootball (default, free WC 2026 JSON), api-football, or mock.
DATA_PROVIDER=openfootball

# Force mock provider even when another source is configured (true/false).
USE_MOCK_DATA=

# OpenFootball WC 2026 data (no API key required)
OPENFOOTBALL_WC2026_URL=https://raw.githubusercontent.com/openfootball/worldcup.json/master/2026/worldcup.json
WC2026_DATA_PATH=data/wc2026/worldcup.json
WC2026_AUTO_SYNC=true

# Cache time-to-live in seconds for provider responses.
CACHE_TTL_SECONDS=3600

# API-Football league ID for FIFA World Cup — update in config.py constants when published.
WORLD_CUP_LEAGUE_ID=1
SEASON=2026

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Weather provider: mock (offline) or openmeteo (free, no API key)
WEATHER_PROVIDER=mock
WEATHER_CACHE_TTL_SECONDS=1800

# API response cache TTLs (seconds)
FIXTURES_CACHE_TTL_SECONDS=300
PREDICTIONS_CACHE_TTL_SECONDS=600

# Background fixture refresh (scheduled/live/finished lists)
REFRESH_ENABLED=true
REFRESH_INTERVAL_SECONDS=300

# Prediction ledger SQLite database
PREDICTIONS_DB_PATH=predictions.db

# Optional admin key for POST /accuracy/recompute (empty = open in dev)
ACCURACY_ADMIN_KEY=

# Model hyperparameters (see README "Hyperparameters")
TEAM_HISTORY_LIMIT=30
SHRINKAGE_PRIOR_MATCHES=8.0
DIXON_COLES_RHO=
WEATHER_DELTA_SCALE=0.35
WEATHER_MIN_BUCKET_SAMPLES=5
INTERCEPT_PRIOR_GOALS=1.35
TIME_DECAY_HALF_LIFE_DAYS=0
MODEL_VERSION=0.2.0
